# ============================================================================
# Path A — LiveKit Cloud + LiveKit Inference (RECOMMENDED for the workshop)
# ============================================================================
# Sign up free at https://cloud.livekit.io (no credit card, $0/mo Build plan).
# These three values are written automatically when you run: lk app env -w
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ============================================================================
# Path B — Direct OpenAI + Deepgram (only needed for livekit_basic_agent.py
# or livekit_mcp_agent.py — NOT required for livekit_inference_agent.py)
# ============================================================================
# OPENAI_API_KEY=sk-...                              # https://platform.openai.com/api-keys
# DEEPGRAM_API_KEY=...                               # https://console.deepgram.com

# ============================================================================
# Optional knobs
# ============================================================================
# LLM_CHOICE=gpt-4.1-mini   # used by livekit_basic_agent.py / livekit_mcp_agent.py
# LOG_LEVEL=INFO
# DEBUG_MODE=false
# RUN_LIVE_EVALS=0          # set to 0 to skip the post-session JudgeGroup
                            # eval in livekit_inference_agent.py (default: 1)
# NO_COLOR=1                # disable ANSI colors in eval verdict output

# ============================================================================
# Path D — LangFuse OpenTelemetry export (optional, for the observability demo)
# ============================================================================
# Sign up free at https://cloud.langfuse.com (Hobby plan = $0, no credit card).
# Set both keys + the host to forward LiveKit traces to LangFuse. Same OTel
# pattern works for Arize, Phoenix, Honeycomb, etc. — swap the host.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # or your self-hosted URL
